pipeline {
    agent any

    environment {
        PYTHON_VERSION = '3.12'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup Python') {
            steps {
                sh '''
                echo "PATH=$PATH"
                which python3 || true
                which pip3 || true
                python3 --version
                python3 -m pip --version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('employee-payroll-management-system') {
                    sh '''
                    python3 -m pip install --upgrade pip
                    python3 -m pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Run Tests') {
            steps {
                sh 'pytest -v'
            }
        }
    }
}
