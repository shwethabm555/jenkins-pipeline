pipeline {
    agent { label 'linux-agent' }

    stages {

        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
            }
        }

        stage('Configure') {
            steps {
                dir('StudentGradeCalculator') {
                    sh '''
                        mkdir -p build
                        cd build
                        cmake ..
                    '''
                }
            }
        }

        stage('Build') {
            steps {
                dir('StudentGradeCalculator') {
                    sh '''
                        cd build
                        cmake --build .
                    '''
                }
            }
        }

        stage('Test & Run') {
            parallel {

                stage('Test') {
                    steps {
                        dir('StudentGradeCalculator') {
                            sh '''
                                test -f build/StudentGradeCalculator
                            '''
                        }
                    }
                }

                stage('Run') {
                    steps {
                        dir('StudentGradeCalculator') {
                            sh '''
                                echo -e "John\n90\n85\n80" | ./build/StudentGradeCalculator
                            '''
                        }
                    }
                }
            }
        }
    }

    post {

        success {
            echo 'Build completed successfully!'
        }

        failure {
            echo 'Build failed.'
        }

        always {
            echo 'Pipeline execution finished.'
        }
    }
}
